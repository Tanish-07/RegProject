        "type": "object",
        "properties": {
          "userId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "emailId": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "LoginDTO": {
        "type": "object",
